# Security headers for every response.
/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Origin-Agent-Cluster: ?1
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://cloudflareinsights.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; upgrade-insecure-requests

# Cloudflare Pages MERGES every matching rule's headers, so a path that
# matches two cache rules gets a doubled Cache-Control. Each path below is
# therefore covered by exactly one rule (no extension glob overlaps a
# directory rule; no /*.js rule that would collide with /_astro/*.js).

# ── Content-addressed: filename changes when content changes ──
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts are large and versioned by filename (new font = new name).
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# ── Unversioned images: stable, but fixed URLs, so cap at 7 days so an
#    updated asset still propagates (covers root + /blog + /projects) ──
/*.svg
  Cache-Control: public, max-age=604800
/*.png
  Cache-Control: public, max-age=604800
/*.webp
  Cache-Control: public, max-age=604800
/*.jpg
  Cache-Control: public, max-age=604800
/*.jpeg
  Cache-Control: public, max-age=604800
/*.gif
  Cache-Control: public, max-age=604800
/*.avif
  Cache-Control: public, max-age=604800

# ── Fixed-URL documents & scripts: revalidate so edits ship on next load
#    instead of being cached for hours ──
/*.html
  Cache-Control: public, max-age=0, must-revalidate
/*.pdf
  Cache-Control: public, max-age=0, must-revalidate
/robots.txt
  Cache-Control: public, max-age=0, must-revalidate
/sitemap*.xml
  Cache-Control: public, max-age=0, must-revalidate
/site.webmanifest
  Cache-Control: public, max-age=0, must-revalidate
  Content-Type: application/manifest+json
/hero-interactions.js
  Cache-Control: public, max-age=0, must-revalidate
/edge-glow.js
  Cache-Control: public, max-age=0, must-revalidate
/codeblock-copy.js
  Cache-Control: public, max-age=0, must-revalidate
