# Security headers for every response.
/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Origin-Agent-Cluster: ?1
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://cloudflareinsights.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; upgrade-insecure-requests

# Cloudflare Pages MERGES every matching rule's headers (comma-joins
# duplicate header values — it does NOT let a more specific rule win), so a
# path that matches two Cache-Control rules ends up with an ambiguous,
# effectively-shorter TTL. `/*.webp` etc. are GLOBAL extension globs — they
# also match /_astro/*.webp, silently downgrading hashed build output from
# immutable to 7 days. Each path below must therefore be reachable by
# exactly one rule: directory-scoped rules for /_astro, /fonts, /projects,
# and an explicit file list for the handful of images that live at the
# public/ root (add new root-level images to that list, not a `/*.ext`
# glob — a glob there will re-introduce the /_astro overlap).

# ── Content-addressed: filename changes when content changes ──
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts are large and versioned by filename (new font = new name).
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# ── Unversioned images: stable, but fixed URLs, so cap at 7 days so an
#    updated asset still propagates ──
/projects/*
  Cache-Control: public, max-age=604800
/apple-touch-icon.png
  Cache-Control: public, max-age=604800
/github.svg
  Cache-Control: public, max-age=604800
/icon-192.png
  Cache-Control: public, max-age=604800
/icon-512.png
  Cache-Control: public, max-age=604800
/icon.svg
  Cache-Control: public, max-age=604800
/linkedin.svg
  Cache-Control: public, max-age=604800
/map-pin.svg
  Cache-Control: public, max-age=604800
/noise.svg
  Cache-Control: public, max-age=604800
/ograph.jpg
  Cache-Control: public, max-age=604800
/opengraph-img.jpg
  Cache-Control: public, max-age=604800
/opengraph.jpg
  Cache-Control: public, max-age=604800
/site-ograph.jpg
  Cache-Control: public, max-age=604800
/xd-32x32-dark.png
  Cache-Control: public, max-age=604800
/xd-32x32-light.png
