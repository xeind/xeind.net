/XD-outline.svg
  Cache-Control: public, max-age=604800

# ── Fixed-URL documents & scripts: revalidate so edits ship on next load
#    instead of being cached for hours ──
/*.html
  Cache-Control: public, max-age=0, must-revalidate
/*.pdf
  Cache-Control: public, max-age=0, must-revalidate
/robots.txt
  Cache-Control: public, max-age=0, must-revalidate
/llms.txt
  Cache-Control: public, max-age=0, must-revalidate
/llms-full.txt
