---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Seo from "../components/Seo.astro";
import { ClientRouter } from "astro:transitions";
import { SITE } from "@/config/site";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalPath?: string;
  noindex?: boolean;
  type?: "website" | "profile" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  keywords?: string[];
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = SITE.name,
  description = SITE.description,
  image = SITE.socialImage,
  canonicalPath = Astro.url.pathname,
  noindex = false,
  type = "website",
  publishedTime,
  modifiedTime,
  keywords,
  structuredData,
} = Astro.props;

const buildCommit = import.meta.env.PUBLIC_GIT_COMMIT_HASH || "dev";
const buildDate = import.meta.env.PUBLIC_BUILD_DATE || new Date().toISOString();
---

<!doctype html>
<html lang={SITE.language}>
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (() => {
        try {
          var themes = ["dark", "light", "nightingale"];
          var root = document.documentElement;
          var saved = localStorage.getItem("theme");
          var theme = themes.includes(saved) ? saved : "dark";

          if (theme === "light") root.removeAttribute("data-theme");
          else root.setAttribute("data-theme", theme);

          if (!window.__themeSwapBound) {
            window.__themeSwapBound = true;
            document.addEventListener("astro:before-swap", function (e) {
              var s = localStorage.getItem("theme");
              var t = themes.includes(s) ? s : "dark";
              if (t === "light") e.newDocument.documentElement.removeAttribute("data-theme");
              else e.newDocument.documentElement.setAttribute("data-theme", t);
            });
          }
        } catch {
          document.documentElement.style.backgroundColor = "#EBE5D8";
        }
      })();
    </script>

    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="theme-color"
      content="#EBE5D8"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#0e1115"
      media="(prefers-color-scheme: dark)"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/xd-32x32-light.png"
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/xd-32x32-dark.png"
      media="(prefers-color-scheme: dark)"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/xd-32x32-light.png"
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/xd-32x32-dark.png"
      media="(prefers-color-scheme: dark)"
    />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link
      rel="preload"
      href="/fonts/Inter-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/Inter-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/LatinModernRoman-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <style is:inline>
      @font-face {
        font-family: Latin Modern Roman;
        src: url(/fonts/LatinModernRoman-Regular.woff2) format("woff2");
        font-weight: 400;
        font-style: normal;
        font-display: optional;
      }
      @font-face {
        font-family: Latin Modern Roman;
        src: url(/fonts/LatinModernRoman-Bold.woff2) format("woff2");
        font-weight: 700;
        font-style: normal;
        font-display: optional;
      }
      @font-face {
        font-family: Inter;
        src: url(/fonts/Inter-Regular.woff2) format("woff2");
        font-weight: 400;
        font-style: normal;
        font-display: optional;
      }
      @font-face {
        font-family: Inter;
        src: url(/fonts/Inter-Bold.woff2) format("woff2");
        font-weight: 700;
        font-style: normal;
        font-display: optional;
      }
      @font-face {
        font-family: JetBrains Mono;
        src: url(/fonts/JetBrainsMono-Variable.woff2) format("woff2");
        font-weight: 100 800;
        font-style: normal;
        font-display: optional;
      }
    </style>

    <Seo
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      image={image}
      noindex={noindex}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      keywords={keywords}
      structuredData={structuredData}
    />
    <ClientRouter />
  </head>
  <body class="font-sans antialiased">
    <div class="paper-background min-h-dvh overflow-x-clip" tabindex="-1">
      <div class="mx-auto max-w-5xl">
        <main
          class="edge-glow-shell edge-glow-shell-vertical bg-card border-accent/20 before:bg-accent/20 after:bg-accent/20 relative isolate mb-(--footer-height) min-h-screen border-x before:absolute before:top-0 before:right-[-9999px] before:left-[-9999px] before:h-px before:content-[''] after:absolute after:right-[-9999px] after:bottom-0 after:left-[-9999px] after:h-px after:content-['']"
        >
          <div class="edge-glow-layer" aria-hidden="true"></div>
          {/* Glow strips on main's own full-bleed top/bottom hairlines —
              the vertical wash only covers the left/right borders. */}
          <div
            class="edge-glow-line absolute top-0 right-[-9999px] left-[-9999px] z-10 h-px"
            aria-hidden="true"
          ></div>
          <div
            class="edge-glow-line absolute right-[-9999px] bottom-0 left-[-9999px] z-10 h-px"
            aria-hidden="true"
          ></div>
          <span
            class="edge-glow-node bg-card border-accent/20 absolute top-[-3.5px] left-[-4.5px] z-20 h-2 w-2 rotate-45 rounded-[1px] border"
          ></span>
          <span
            class="edge-glow-node bg-card border-accent/20 absolute top-[-3.5px] right-[-4.5px] z-20 h-2 w-2 rotate-45 rounded-[1px] border"
          ></span>
          <span
            class="edge-glow-node bg-card border-accent/20 absolute bottom-[-3.5px] left-[-4.5px] z-20 h-2 w-2 rotate-45 rounded-[1px] border"
          ></span>
          <span
            class="edge-glow-node bg-card border-accent/20 absolute right-[-4.5px] bottom-[-3.5px] z-20 h-2 w-2 rotate-45 rounded-[1px] border"
          ></span>
          <slot />
        </main>
      </div>
      <Footer commit={buildCommit} buildDate={buildDate} />
    </div>

    <script is:inline src="/hero-interactions.js" defer></script>
    <script is:inline src="/codeblock-copy.js" defer></script>
    <script is:inline src="/edge-glow.js" defer></script>
  </body>
</html>
