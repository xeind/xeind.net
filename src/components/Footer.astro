---
interface Props {
  commit: string;
  buildDate: string;
}

const { commit, buildDate } = Astro.props;
const date = new Date(buildDate);
const year = Number.isNaN(date.getTime()) ? new Date().getFullYear() : date.getFullYear();
const compactDate = Number.isNaN(date.getTime())
  ? "dev"
  : date.toISOString().slice(0, 10).replaceAll("-", "");
---

<footer
  class="text-foreground fixed right-0 bottom-0 left-0 -z-10"
  style="height:var(--footer-height)"
>
  <div class="bg-accent absolute inset-0"></div>
  <div class="relative mx-auto h-full w-full max-w-5xl">
    <div class="relative z-10 flex h-full items-center p-6 px-6 sm:px-8 md:p-8 md:px-12">
      <div class="grid w-full grid-cols-[1fr_auto] items-center gap-4 sm:gap-6 md:gap-8">
        <div class="flex flex-col gap-1">
          <p class="text-background flex items-center gap-2 font-mono text-xs">
            <span>© {year} XD</span>
            <span class="bg-background inline-block h-1 w-1 shrink-0"></span>
            <a
              href="/design"
              class="border-background/30 text-background/50 border-b border-dashed pb-px"
            >
              Design
            </a>
          </p>
          <p class="text-background flex items-center gap-1.5 font-mono text-xs">
            <span>Shipped with</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="11"
              height="14"
              viewBox="0 0 64 80"
              fill="none"
              class="shrink-0"
              aria-hidden="true"
            >
              <path
                d="M20.5253 67.6322C16.9291 64.3531 15.8793 57.4632 17.3776 52.4717C19.9755 55.6188 23.575 56.6157 27.3035 57.1784C33.0594 58.0468 38.7122 57.722 44.0592 55.0977C44.6709 54.7972 45.2362 54.3978 45.9045 53.9931C46.4062 55.4451 46.5368 56.9109 46.3616 58.4028C45.9355 62.0362 44.1228 64.8429 41.2397 66.9705C40.0868 67.8215 38.8669 68.5822 37.6762 69.3846C34.0181 71.8508 33.0285 74.7426 34.403 78.9491C34.4357 79.0516 34.4649 79.1541 34.5388 79.4042C32.6711 78.5705 31.3069 77.3565 30.2674 75.7604C29.1694 74.0757 28.6471 72.2121 28.6196 70.1957C28.6059 69.2144 28.6059 68.2244 28.4736 67.257C28.1506 64.8985 27.0406 63.8425 24.9496 63.7817C22.8036 63.7192 21.106 65.0426 20.6559 67.1268C20.6215 67.2865 20.5717 67.4446 20.5218 67.6304L20.5253 67.6322Z"
                fill="currentColor"></path>
              <path
                d="M20.5253 67.6322C16.9291 64.3531 15.8793 57.4632 17.3776 52.4717C19.9755 55.6188 23.575 56.6157 27.3035 57.1784C33.0594 58.0468 38.7122 57.722 44.0592 55.0977C44.6709 54.7972 45.2362 54.3978 45.9045 53.9931C46.4062 55.4451 46.5368 56.9109 46.3616 58.4028C45.9355 62.0362 44.1228 64.8429 41.2397 66.9705C40.0868 67.8215 38.8669 68.5822 37.6762 69.3846C34.0181 71.8508 33.0285 74.7426 34.403 78.9491C34.4357 79.0516 34.4649 79.1541 34.5388 79.4042C32.6711 78.5705 31.3069 77.3565 30.2674 75.7604C29.1694 74.0757 28.6471 72.2121 28.6196 70.1957C28.6059 69.2144 28.6059 68.2244 28.4736 67.257C28.1506 64.8985 27.0406 63.8425 24.9496 63.7817C22.8036 63.7192 21.106 65.0426 20.6559 67.1268C20.6215 67.2865 20.5717 67.4446 20.5218 67.6304L20.5253 67.6322Z"
                fill="currentColor"></path>
              <path
                d="M0 51.6401C0 51.6401 10.6488 46.4654 21.3274 46.4654L29.3786 21.6102C29.6801 20.4082 30.5602 19.5913 31.5538 19.5913C32.5474 19.5913 33.4275 20.4082 33.7289 21.6102L41.7802 46.4654C54.4274 46.4654 63.1076 51.6401 63.1076 51.6401C63.1076 51.6401 45.0197 2.48776 44.9843 2.38914C44.4652 0.935933 43.5888 0 42.4073 0H20.7022C19.5206 0 18.6796 0.935933 18.1251 2.38914C18.086 2.4859 0 51.6401 0 51.6401Z"
                fill="currentColor"></path>
              <defs>
                <linearGradient
                  id="astro-footer-gradient"
                  x1="31.554"
                  y1="75.4423"
                  x2="39.7462"
                  y2="48.376"
                  gradientUnits="userSpaceOnUse"
                >
                  <stop stop-color="var(--color-secondary)"></stop>
                  <stop offset="1" stop-color="var(--color-tertiary)"></stop>
                </linearGradient>
              </defs>
            </svg>
            <span>Astro</span>
          </p>
          <p class="text-background hidden items-center gap-2 font-mono text-xs sm:flex">
            Latin Modern
            <span class="bg-background inline-block h-1 w-1 shrink-0"></span>
            Inter
            <span class="bg-background inline-block h-1 w-1 shrink-0"></span>
            JetBrains Mono
          </p>
          <p class="text-background flex items-center gap-2 font-mono text-xs opacity-70">
            {commit}
            <span class="bg-background inline-block h-1 w-1 shrink-0"></span>
            Last Built: {compactDate}
          </p>
        </div>

        <button
          type="button"
          data-theme-cycle
          class="bg-card text-foreground hover:bg-muted focus-visible:ring-accent relative inline-flex min-h-8 items-center gap-2 px-3 py-1.5 font-mono text-xs focus-visible:ring-2 focus-visible:outline-none"
        >
          <span class="sr-only">Theme:</span>
          <span data-theme-label>Manila</span>
        </button>
      </div>
    </div>
  </div>
</footer>

<script>
  type ThemeName = "dark" | "light" | "nightingale";
  const themes: ThemeName[] = ["dark", "light", "nightingale"];
  const labels = {
    dark: "Manila",
    light: "Kozo",
    nightingale: "Nightingale",
  } satisfies Record<ThemeName, string>;

  function isThemeName(value: string | null): value is ThemeName {
    return value !== null && themes.includes(value as ThemeName);
  }

  function applyTheme(theme: ThemeName) {
    if (theme === "light") {
      document.documentElement.removeAttribute("data-theme");
    } else {
      document.documentElement.setAttribute("data-theme", theme);
    }
    document
      .querySelectorAll<HTMLElement>("[data-theme-label]")
      .forEach((el) => (el.textContent = labels[theme]));
  }

  function syncTheme() {
    const saved = localStorage.getItem("theme");
    if (isThemeName(saved)) {
      applyTheme(saved);
    }
  }

  /* Initial sync */
  syncTheme();

  /* Sync labels after ClientRouter navigation (theme is already
     applied on the new document by the head inline script's
     astro:before-swap handler) */
  document.addEventListener("astro:after-swap", syncTheme);

  /* Event delegation — survives ClientRouter DOM swaps */
  document.addEventListener("click", (e) => {
    const target = e.target;
    if (!(target instanceof Element)) return;
    const btn = target.closest("[data-theme-cycle]");
    if (!btn) return;
    const saved = localStorage.getItem("theme");
    const current: ThemeName = isThemeName(saved) ? saved : "dark";
    const next = themes[(themes.indexOf(current) + 1) % themes.length];
    localStorage.setItem("theme", next);
    applyTheme(next);
  });
</script>
