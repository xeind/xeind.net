---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Page Not Found | Xein Deniel"
  description="The requested page could not be found."
  canonicalPath="/404"
  noindex
>
  <div
    class="flex min-h-[60vh] flex-col items-center justify-center px-6 py-12"
  >
    <div class="max-w-md text-center">
      <h1
        class="text-foreground/60 mb-4 font-mono text-6xl font-bold tracking-tight"
      >
        404
      </h1>
      <h2 class="text-foreground mb-3 font-serif text-2xl">Page Not Found</h2>
      <p class="text-foreground/80 mb-8 text-sm leading-relaxed">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="bg-card border-accent/30 text-foreground hover:border-accent/50 hover:bg-muted focus-visible:ring-accent inline-flex items-center gap-2 border px-6 py-2 font-serif text-sm transition-colors focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none"
      >
        <span aria-hidden="true">←</span>
        <span>Back to Home</span>
      </a>
    </div>
  </div>
</Layout>
