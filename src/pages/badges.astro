---
import Layout from "../layouts/Layout.astro";
import Badge from "@/components/ui/Badge";
import Panel from "@/components/ui/Panel";
---

<Layout
  title="Badge Demo | Xein Deniel"
  description="Badge component design examples."
  canonicalPath="/badges"
  noindex
>
  <Panel edges="both" ornaments="bottom">
    <div class="space-y-8">
      <h1 class="text-foreground font-serif text-2xl font-bold">
        Badge Component Demo
      </h1>

      <section>
        <h2 class="text-foreground mb-3 font-serif text-lg">Default Variant</h2>
        <div class="flex flex-wrap gap-2">
          <Badge>TypeScript</Badge>
          <Badge>React</Badge>
          <Badge>Astro</Badge>
          <Badge>Tailwind CSS</Badge>
          <Badge>PostgreSQL</Badge>
          <Badge>Node.js</Badge>
        </div>
      </section>

      <section>
        <h2 class="text-foreground mb-3 font-serif text-lg">
          Accent Variant
        </h2>
        <div class="flex flex-wrap gap-2">
          <Badge variant="accent">Featured</Badge>
          <Badge variant="accent">New</Badge>
          <Badge variant="accent">Popular</Badge>
        </div>
      </section>

      <section>
        <h2 class="text-foreground mb-3 font-serif text-lg">Muted Variant</h2>
        <div class="flex flex-wrap gap-2">
          <Badge variant="muted">2026</Badge>
          <Badge variant="muted">In Progress</Badge>
          <Badge variant="muted">Archive</Badge>
        </div>
      </section>
    </div>
  </Panel>
</Layout>
