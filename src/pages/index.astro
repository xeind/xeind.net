---
import Layout from "../layouts/Layout.astro";
import HeroSection from "@/components/hero/HeroSection";
import AboutSection from "@/components/sections/AboutSection";
import ExperienceTimeline from "@/components/sections/ExperienceTimeline";
import ProjectGrid from "@/components/sections/ProjectGrid";
import CalloutBand from "@/components/ui/CalloutBand";
import Panel from "@/components/ui/Panel";
import SectionDivider from "@/components/ui/SectionDivider";
import { SITE, absoluteUrl } from "@/lib/config/site";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": absoluteUrl("/#person"),
      name: SITE.name,
      url: SITE.url,
      image: absoluteUrl(SITE.socialImage),
      email: SITE.email,
      jobTitle: SITE.jobTitle,
      address: {
        "@type": "PostalAddress",
        addressCountry: "PH",
        addressLocality: SITE.location,
      },
      sameAs: SITE.profiles,
      knowsAbout: [
        "Interface design",
        "Web development",
        "TypeScript",
        "React",
        "Astro",
        "Rust",
        "Web performance",
      ],
    },
    {
      "@type": "WebSite",
      "@id": absoluteUrl("/#website"),
      url: SITE.url,
      name: SITE.name,
      inLanguage: SITE.language,
      publisher: { "@id": absoluteUrl("/#person") },
    },
    {
      "@type": "ProfilePage",
      "@id": absoluteUrl("/#profile"),
      url: absoluteUrl("/"),
      name: `${SITE.name} — ${SITE.jobTitle}`,
      description: SITE.description,
      isPartOf: { "@id": absoluteUrl("/#website") },
      mainEntity: { "@id": absoluteUrl("/#person") },
    },
  ],
};
---

<Layout
  title={`${SITE.name} — ${SITE.jobTitle}`}
  description={SITE.description}
  canonicalPath="/"
  type="profile"
  structuredData={structuredData}
>
  <div class="flex flex-col">
    <CalloutBand href="/blog" label="Visit my blog" />

    <Panel tone="hero" padding="lg" edges="bottom" ornaments="bottom">
      <HeroSection />
    </Panel>
    <SectionDivider variant="grid" />

    <Panel>
      <AboutSection />
    </Panel>
    <SectionDivider variant="grid" />

    <Panel>
      <ExperienceTimeline />
    </Panel>
    <SectionDivider variant="grid" />

    {/* Last section on purpose: the grid is the page's only React island
        (~100KB with the runtime), so it sits below Experience where its
        client:visible fetch happens while the reader scrolls — out of the
        initial load's critical window. rootMargin pre-fetches ~a third of
        a viewport early so it's hydrated on arrival; it must stay smaller
        than the grid's ~600px gap below the mobile fold or the fetch
        fires at load and defeats the deferral. */}
    <Panel>
      <ProjectGrid client:visible={{ rootMargin: "300px" }} />
    </Panel>
  </div>

  <script is:inline>
    (() => {
      const files = ["fmeet-seo", "smeet-seo", "nightingale"];
      const themes = ["light", "dark", "nightingale"];
      const themeAttribute = document.documentElement.getAttribute("data-theme");
      const activeTheme = themes.includes(themeAttribute) ? themeAttribute : "light";

      document.querySelectorAll("[data-project-logo]").forEach((logo) => {
        const file = logo.getAttribute("data-project-logo");
        if (file) logo.setAttribute("src", `/projects/${file}-${activeTheme}.svg`);
      });

      const preloadAlternateLogos = () => {
        window.__projectLogoPreload ??= Promise.all(
          files.flatMap((file) =>
            themes
              .filter((theme) => theme !== activeTheme)
              .map(
                (theme) =>
                  new Promise((resolve) => {
                    const image = new Image();
                    image.onload = resolve;
                    image.onerror = resolve;
                    image.src = `/projects/${file}-${theme}.svg`;
                  }),
              ),
          ),
        ).then(() => undefined);
      };

      if (document.readyState === "complete") {
        preloadAlternateLogos();
      } else {
        window.addEventListener("load", () => window.setTimeout(preloadAlternateLogos, 0), {
          once: true,
        });
      }
    })();
  </script>
</Layout>
