---
import Layout from "../layouts/Layout.astro";
import HeroSection from "@/components/hero/HeroSection";
import AboutSection from "@/components/sections/AboutSection";
import ExperienceTimeline from "@/components/sections/ExperienceTimeline";
import ProjectGrid from "@/components/sections/ProjectGrid";
import CalloutBand from "@/components/ui/CalloutBand";
import Panel from "@/components/ui/Panel";
import SectionDivider from "@/components/ui/SectionDivider";
import { SITE, absoluteUrl } from "@/lib/config/site";
import { PROJECT_LOGO_URLS } from "@/lib/data/project-logo-urls";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": absoluteUrl("/#person"),
      name: SITE.name,
      url: SITE.url,
      image: absoluteUrl(SITE.socialImage),
      email: SITE.email,
      jobTitle: SITE.jobTitle,
      address: {
        "@type": "PostalAddress",
        addressCountry: "PH",
        addressLocality: SITE.location,
      },
      sameAs: SITE.profiles,
      knowsAbout: [
        "Interface design",
        "Web development",
        "TypeScript",
        "React",
        "Astro",
        "Rust",
        "Web performance",
      ],
    },
    {
      "@type": "WebSite",
      "@id": absoluteUrl("/#website"),
      url: SITE.url,
      name: SITE.name,
      inLanguage: SITE.language,
      publisher: { "@id": absoluteUrl("/#person") },
    },
    {
      "@type": "ProfilePage",
      "@id": absoluteUrl("/#profile"),
      url: absoluteUrl("/"),
      name: `${SITE.name} — ${SITE.jobTitle}`,
      description: SITE.description,
      isPartOf: { "@id": absoluteUrl("/#website") },
      mainEntity: { "@id": absoluteUrl("/#person") },
    },
  ],
};
---

<Layout
  title={`${SITE.name} — ${SITE.jobTitle}`}
  description={SITE.description}
  canonicalPath="/"
  type="profile"
  structuredData={structuredData}
>
  <div class="flex flex-col">
    <CalloutBand href="/blog" label="Visit my blog" />

    <Panel tone="hero" padding="lg" edges="bottom" ornaments="bottom">
      <HeroSection />
    </Panel>
    <SectionDivider variant="grid" />

    <Panel>
      <AboutSection />
    </Panel>
    <SectionDivider variant="grid" />

    <Panel>
      <ExperienceTimeline />
    </Panel>
    <SectionDivider variant="grid" />

    {
      /* Last section on purpose: the grid is the page's only React island
        (~100KB with the runtime), so it sits below Experience where its
        client:visible fetch happens while the reader scrolls — out of the
        initial load's critical window. rootMargin pre-fetches ~a third of
        a viewport early so it's hydrated on arrival; it must stay smaller
        than the grid's ~600px gap below the mobile fold or the fetch
        fires at load and defeats the deferral. */
    }
    <Panel>
      <ProjectGrid client:visible={{ rootMargin: "300px" }} />
    </Panel>
  </div>

  <script is:inline define:vars={{ logoUrls: PROJECT_LOGO_URLS }}>
    (() => {
      const themes = ["light", "dark", "nightingale"];

      const getActiveTheme = () => {
        const themeAttribute = document.documentElement.getAttribute("data-theme");
        return themes.includes(themeAttribute) ? themeAttribute : "light";
      };

      const applyActiveLogoSources = () => {
        const activeTheme = getActiveTheme();
        document.querySelectorAll("[data-project-logo]").forEach((logo) => {
          const file = logo.getAttribute("data-project-logo");
          if (file && logoUrls[file]) logo.setAttribute("src", logoUrls[file][activeTheme]);
        });
      };

      applyActiveLogoSources();
      /* ClientRouter swaps in the prebuilt HTML (dark srcs baked by SSR) but
         de-dupes inline scripts, so this script won't re-run when navigating
         back here from the blog. The document persists across swaps, so this
         listener does the re-correction instead. */
      document.addEventListener("astro:after-swap", applyActiveLogoSources);

      /* Preload the other themes' variants only on theme-switch intent
         (hover/focus on the cycle button) — not on every page load. */
      const preloadAlternateLogos = () => {
        const activeTheme = getActiveTheme();
        window.__projectLogoPreload ??= Promise.all(
          Object.values(logoUrls).flatMap((byTheme) =>
            themes
              .filter((theme) => theme !== activeTheme)
              .map(
                (theme) =>
                  new Promise((resolve) => {
                    const image = new Image();
                    image.onload = resolve;
                    image.onerror = resolve;
                    image.src = byTheme[theme];
                  }),
              ),
          ),
        ).then(() => undefined);
      };

      const onIntent = (event) => {
        if (event.target instanceof Element && event.target.closest("[data-theme-cycle]")) {
          preloadAlternateLogos();
        }
      };
      document.addEventListener("pointerover", onIntent, { passive: true });
      document.addEventListener("focusin", onIntent);
    })();
  </script>

  <script>
    import { animate } from "motion";

    const EASE: [number, number, number, number] = [0.2, 0, 0, 1];
    const revertTimers = new WeakMap<Element, ReturnType<typeof setTimeout>>();

    document.addEventListener("click", (event) => {
      if (!(event.target instanceof Element)) return;
      const btn = event.target.closest("[data-copy-email]");
      if (!btn) return;

      const email = btn.getAttribute("data-copy-email");
      const mail = btn.querySelector('[data-email-icon="mail"]');
      const check = btn.querySelector('[data-email-icon="check"]');
      if (!email || !mail || !check) return;

      navigator.clipboard.writeText(email).then(() => {
        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const options = { duration: reduceMotion ? 0 : 0.18, ease: EASE };

        clearTimeout(revertTimers.get(btn));
        animate(mail, { scale: 0.25, opacity: 0, filter: "blur(4px)" }, options);
        animate(check, { scale: 1, opacity: 1, filter: "blur(0px)" }, options);
        btn.setAttribute("aria-label", "Copied");

        revertTimers.set(
          btn,
          setTimeout(() => {
            animate(mail, { scale: 1, opacity: 1, filter: "blur(0px)" }, options);
            animate(check, { scale: 0.25, opacity: 0, filter: "blur(4px)" }, options);
            btn.setAttribute("aria-label", "Copy email address");
          }, 2000),
        );
      });
    });
  </script>
</Layout>
