---
import Layout from "../layouts/Layout.astro";
import Panel from "@/components/ui/Panel";
import SectionDivider from "@/components/ui/SectionDivider";
import Badge from "@/components/ui/Badge";
import InlineLink from "@/components/ui/InlineLink";
import CornerDiamond from "@/components/ui/CornerDiamond";
import CtaButton from "@/components/ui/CtaButton.astro";
import GridIterations from "@/components/design/GridIterations";
import EdgeOrnaments from "@/components/design/EdgeOrnaments";
import PrecisionMarks from "@/components/design/PrecisionMarks";
---

<Layout
  title="Design System | Xein Deniel"
  description="Design tokens, components, and patterns."
  canonicalPath="/design"
  noindex
>
  <div class="flex flex-col">
    {/* Header */}
    <Panel tone="hero" padding="lg" edges="both" ornaments="bottom">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-foreground font-serif text-2xl">Design System</h1>
          <p class="text-foreground/60 mt-2 text-sm">
            Tokens, components, and patterns used across xeind.net.
          </p>
        </div>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 7083.94 7553"
          class="text-foreground h-12 w-auto opacity-20"
          aria-label="XD logo"
        >
          <polygon fill="currentColor" points="2195.38 3776.32 3297.59 2674.1 3297.4 0 1881.17 817.66 1881.17 1700.09 2533.38 1323.54 2533.38 2357.55 1114.63 3776.31 1114.62 3776.31 0 4890.93 0 5648.88 1394.13 6453.77 1394.13 5571.34 764.22 5207.47 2195.38 3776.32 2195.38 3776.32"/>
          <polygon fill="currentColor" opacity="0.6" points="2195.37 3776.32 2195.38 3776.32 764.21 2345.15 1394.12 1981.29 1394.12 1098.86 0 1903.75 0 2661.7 1114.62 3776.32 1114.61 3776.32 2533.38 5195.08 2533.38 6229.09 1881.16 5852.54 1881.16 6734.97 3297.39 7552.63 3297.59 4878.53 2195.37 3776.32"/>
          <polygon fill="currentColor" points="7083.94 1904.96 5689.01 1099.6 5689.01 1982.03 6319.7 2346.16 6319.7 3776.32 6319.7 5206.48 5689.01 5570.6 5689.01 6453.04 7083.94 5647.67 7083.91 3776.32 7083.94 1904.96"/>
          <polygon fill="currentColor" opacity="0.6" points="4549 1323.84 5201.96 1700.83 5201.96 818.4 3784.45 0 3784.45 2876.03 2883.98 3776.5 3784.45 4676.97 3784.45 7553 5201.96 6734.6 5201.96 5852.17 4549 6229.16 4549 4360.76 3964.74 3776.5 4549 3192.24 4549 1323.84"/>
        </svg>
      </div>
    </Panel>
    <SectionDivider />

    {/* Typography */}
    <Panel>
      <h2 class="text-accent mb-6 font-mono text-xs tracking-wide">
        TYPOGRAPHY
      </h2>

      <div class="space-y-6">
        <div>
          <p class="text-foreground/50 mb-2 font-mono text-xs">
            font-serif · Latin Modern Roman
          </p>
          <p class="text-foreground font-serif text-2xl">
            The quick brown fox jumps over the lazy dog
          </p>
          <p class="text-foreground font-serif text-xl">
            The quick brown fox jumps over the lazy dog
          </p>
          <p class="text-foreground font-serif text-lg">
            The quick brown fox jumps over the lazy dog
          </p>
          <p class="text-foreground font-serif text-base">
            The quick brown fox jumps over the lazy dog
          </p>
        </div>

        <div class="border-accent/20 border-t border-dashed"></div>

        <div>
          <p class="text-foreground/50 mb-2 font-mono text-xs">
            font-sans · Inter
          </p>
          <p class="text-foreground font-sans text-sm">
            The quick brown fox jumps over the lazy dog
          </p>
          <p class="text-foreground font-sans text-xs">
            The quick brown fox jumps over the lazy dog
          </p>
        </div>

        <div class="border-accent/20 border-t border-dashed"></div>

        <div>
          <p class="text-foreground/50 mb-2 font-mono text-xs">
            font-mono · JetBrains Mono
          </p>
          <p class="text-foreground font-mono text-sm">
            The quick brown fox jumps over the lazy dog
          </p>
          <p class="text-foreground font-mono text-xs">
            0123456789 !@#$%^&amp;*() const fn =&gt; {"{}"}
          </p>
        </div>
      </div>
    </Panel>
    <SectionDivider />

    {/* Colors */}
    <Panel>
      <div class="mb-6 flex items-start justify-between">
        <h2 class="text-accent font-mono text-xs tracking-wide">COLORS</h2>
        <button
          type="button"
          data-theme-cycle
          class="border-accent/30 bg-card text-foreground hover:bg-muted hover:border-accent/50 focus-visible:ring-accent relative inline-flex min-h-8 items-center gap-2 border border-dashed px-3 py-1.5 font-mono text-xs transition-colors focus-visible:ring-2 focus-visible:outline-none"
          aria-label="Theme"
        >
          <span data-theme-label>Manila</span>
        </button>
      </div>

      <div class="mb-6 space-y-3">
        <div>
          <p class="text-foreground font-serif text-base">Kozo</p>
          <p class="text-foreground/50 text-sm leading-relaxed">Light — inspired by paperlike e-ink screens and mulberry fiber paper</p>
        </div>
        <div class="border-accent/20 border-t border-dashed"></div>
        <div>
          <p class="text-foreground font-serif text-base">Manila</p>
          <p class="text-foreground/50 text-sm leading-relaxed">Dark — named after the city where I studied, sodium lamps and night traffic</p>
        </div>
        <div class="border-accent/20 border-t border-dashed"></div>
        <div>
          <p class="text-foreground font-serif text-base">Nightingale</p>
          <p class="text-foreground/50 text-sm leading-relaxed">My personal theme, ported from my Neovim colorscheme</p>
        </div>
      </div>

      <div class="border-accent/20 mb-6 border-t border-dashed"></div>

      <p class="text-foreground/50 mb-4 font-mono text-xs">
        Nine shared tokens
      </p>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
        {
          [
            { name: "background", cls: "bg-background" },
            { name: "foreground", cls: "bg-foreground" },
            { name: "card", cls: "bg-card" },
            { name: "muted", cls: "bg-muted" },
            { name: "accent", cls: "bg-accent" },
            { name: "tertiary", cls: "bg-tertiary" },
            { name: "secondary", cls: "bg-secondary" },
            { name: "border", cls: "bg-border" },
          ].map((c) => (
            <div class="flex items-center gap-3">
              <div
                class={`border-accent/20 h-8 w-8 shrink-0 border border-dashed ${c.cls}`}
              />
              <span class="text-foreground/60 font-mono text-xs">{c.name}</span>
            </div>
          ))
        }
      </div>
    </Panel>
    <SectionDivider />

    {/* Syntax Colors */}
    <Panel>
      <h2 class="text-accent mb-6 font-mono text-xs tracking-wide">
        SYNTAX COLORS
      </h2>
      <p class="text-foreground/50 mb-4 font-mono text-xs">
        Code block token colors per theme — switch themes to see each palette
      </p>

      <div class="mb-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
        {
          [
            { name: "keyword", css: "var(--astro-code-token-keyword)" },
            { name: "function", css: "var(--astro-code-token-function)" },
            { name: "string", css: "var(--astro-code-token-string)" },
            { name: "constant", css: "var(--astro-code-token-constant)" },
            { name: "parameter", css: "var(--astro-code-token-parameter)" },
            { name: "comment", css: "var(--astro-code-token-comment)" },
            { name: "punctuation", css: "var(--astro-code-token-punctuation)" },
            { name: "foreground", css: "var(--astro-code-foreground)" },
          ].map((c) => (
            <div class="flex items-center gap-3">
              <div
                class="border-accent/20 h-8 w-8 shrink-0 border border-dashed"
                style={`background-color: ${c.css}`}
              />
              <span class="text-foreground/60 font-mono text-xs">{c.name}</span>
            </div>
          ))
        }
      </div>

      <div class="border-accent/20 mb-4 border-t border-dashed"></div>

      <p class="text-foreground/50 mb-3 font-mono text-xs">Sample</p>
      <pre
        class="border-accent/15 bg-muted overflow-x-auto border border-dashed p-4 font-mono text-[0.8125rem] leading-relaxed"
      ><code><span style="color: var(--astro-code-token-keyword)">interface</span> <span style="color: var(--astro-code-token-constant)">Theme</span> <span style="color: var(--astro-code-token-punctuation)">{"{"}</span>
  <span style="color: var(--astro-code-token-parameter)">name</span><span style="color: var(--astro-code-token-punctuation)">:</span> <span style="color: var(--astro-code-token-constant)">string</span><span style="color: var(--astro-code-token-punctuation)">;</span>
  <span style="color: var(--astro-code-token-parameter)">origin</span><span style="color: var(--astro-code-token-punctuation)">:</span> <span style="color: var(--astro-code-token-constant)">string</span><span style="color: var(--astro-code-token-punctuation)">;</span>
<span style="color: var(--astro-code-token-punctuation)">{"}"}</span>

<span style="color: var(--astro-code-token-keyword)">const</span> <span style="color: var(--astro-code-token-constant)">themes</span><span style="color: var(--astro-code-token-punctuation)">:</span> <span style="color: var(--astro-code-token-constant)">Theme</span><span style="color: var(--astro-code-token-punctuation)">[]</span> <span style="color: var(--astro-code-token-punctuation)">=</span> <span style="color: var(--astro-code-token-punctuation)">[</span>
  <span style="color: var(--astro-code-token-punctuation)">{"{"}</span> <span style="color: var(--astro-code-token-parameter)">name</span><span style="color: var(--astro-code-token-punctuation)">:</span> <span style="color: var(--astro-code-token-string)">"kozo"</span><span style="color: var(--astro-code-token-punctuation)">,</span> <span style="color: var(--astro-code-token-parameter)">origin</span><span style="color: var(--astro-code-token-punctuation)">:</span> <span style="color: var(--astro-code-token-string)">"mulberry paper"</span> <span style="color: var(--astro-code-token-punctuation)">{"}"}</span><span style="color: var(--astro-code-token-punctuation)">,</span>
  <span style="color: var(--astro-code-token-punctuation)">{"{"}</span> <span style="color: var(--astro-code-token-parameter)">name</span><span style="color: var(--astro-code-token-punctuation)">:</span> <span style="color: var(--astro-code-token-string)">"manila"</span><span style="color: var(--astro-code-token-punctuation)">,</span> <span style="color: var(--astro-code-token-parameter)">origin</span><span style="color: var(--astro-code-token-punctuation)">:</span> <span style="color: var(--astro-code-token-string)">"city lights"</span> <span style="color: var(--astro-code-token-punctuation)">{"}"}</span><span style="color: var(--astro-code-token-punctuation)">,</span>
  <span style="color: var(--astro-code-token-punctuation)">{"{"}</span> <span style="color: var(--astro-code-token-parameter)">name</span><span style="color: var(--astro-code-token-punctuation)">:</span> <span style="color: var(--astro-code-token-string)">"nightingale"</span><span style="color: var(--astro-code-token-punctuation)">,</span> <span style="color: var(--astro-code-token-parameter)">origin</span><span style="color: var(--astro-code-token-punctuation)">:</span> <span style="color: var(--astro-code-token-string)">"neovim"</span> <span style="color: var(--astro-code-token-punctuation)">{"}"}</span><span style="color: var(--astro-code-token-punctuation)">,</span>
<span style="color: var(--astro-code-token-punctuation)">]</span><span style="color: var(--astro-code-token-punctuation)">;</span>

<span style="color: var(--astro-code-token-comment)">// Each theme adapts to its environment</span>
<span style="color: var(--astro-code-token-keyword)">function</span> <span style="color: var(--astro-code-token-function)">apply</span><span style="color: var(--astro-code-token-punctuation)">(</span><span style="color: var(--astro-code-token-parameter)">theme</span><span style="color: var(--astro-code-token-punctuation)">:</span> <span style="color: var(--astro-code-token-constant)">Theme</span><span style="color: var(--astro-code-token-punctuation)">)</span> <span style="color: var(--astro-code-token-punctuation)">{"{"}</span>
  <span style="color: var(--astro-code-token-keyword)">return</span> <span style="color: var(--astro-code-token-string)">{"`${theme.name}: ${theme.origin}`"}</span><span style="color: var(--astro-code-token-punctuation)">;</span>
<span style="color: var(--astro-code-token-punctuation)">{"}"}</span></code></pre>
    </Panel>
    <SectionDivider />

    {/* Borders & Ornaments */}
    <Panel>
      <h2 class="text-accent mb-6 font-mono text-xs tracking-wide">
        BORDERS &amp; ORNAMENTS
      </h2>

      <div class="space-y-6">
        <div>
          <p class="text-foreground/50 mb-3 font-mono text-xs">
            Dashed borders · hover → solid
          </p>
          <div
            class="group border-accent/30 relative inline-block cursor-pointer border border-dashed px-6 py-3 transition-all hover:border-solid"
          >
            <span class="text-foreground font-serif text-sm">Hover me</span>
          </div>
        </div>

        <div class="border-accent/20 border-t border-dashed"></div>

        <div>
          <p class="text-foreground/50 mb-3 font-mono text-xs">
            Corner diamonds
          </p>
          <div class="border-accent/20 relative border border-dashed px-6 py-4">
            <CornerDiamond position="all" variant="accent" />
            <span class="text-foreground/80 font-serif text-sm"
              >Panel with corner ornaments</span
            >
          </div>
        </div>

        <div class="border-accent/20 border-t border-dashed"></div>

        <div>
          <p class="text-foreground/50 mb-3 font-mono text-xs">
            Corner brackets · expand on hover
          </p>
          <div class="group relative inline-block px-6 py-4">
            <div class="ca-tl"></div>
            <div class="ca-tr"></div>
            <div class="ca-bl"></div>
            <div class="ca-br"></div>
            <span class="text-foreground/80 font-serif text-sm"
              >Hover to expand brackets</span
            >
          </div>
        </div>

        <div class="border-accent/20 border-t border-dashed"></div>

        <div>
          <p class="text-foreground/50 mb-3 font-mono text-xs">
            Section divider — full-bleed hairlines stand in for the adjacent
            panel edges the glow overlays
          </p>
          <div class="relative -mx-5 py-px sm:-mx-8 md:-mx-12">
            <div class="bg-accent/20 absolute top-0 right-[-9999px] left-[-9999px] h-px"></div>
            <div class="bg-accent/20 absolute bottom-0 right-[-9999px] left-[-9999px] h-px"></div>
            <CornerDiamond position="all" variant="accent" />
            <SectionDivider />
          </div>
        </div>

        <div class="border-accent/20 border-t border-dashed"></div>

        <div>
          <p class="text-foreground/50 mb-3 font-mono text-xs">
            Section divider variants
          </p>
          <div class="space-y-4">
            <div>
              <p class="text-foreground/40 mb-2 font-mono text-[0.6875rem]">
                dashed
              </p>
              <div class="relative -mx-5 py-px sm:-mx-8 md:-mx-12">
                <div class="bg-accent/20 absolute top-0 right-[-9999px] left-[-9999px] h-px"></div>
                <div class="bg-accent/20 absolute bottom-0 right-[-9999px] left-[-9999px] h-px"></div>
                <CornerDiamond position="all" variant="accent" />
                <SectionDivider variant="dashed" />
              </div>
            </div>
            <div>
              <p class="text-foreground/40 mb-2 font-mono text-[0.6875rem]">
                grid
              </p>
              <div class="relative -mx-5 py-px sm:-mx-8 md:-mx-12">
                <div class="bg-accent/20 absolute top-0 right-[-9999px] left-[-9999px] h-px"></div>
                <div class="bg-accent/20 absolute bottom-0 right-[-9999px] left-[-9999px] h-px"></div>
                <CornerDiamond position="all" variant="accent" />
                <SectionDivider variant="grid" />
              </div>
            </div>
            <div>
              <p class="text-foreground/40 mb-2 font-mono text-[0.6875rem]">
                grid-broken
              </p>
              <div class="relative -mx-5 py-px sm:-mx-8 md:-mx-12">
                <div class="bg-accent/20 absolute top-0 right-[-9999px] left-[-9999px] h-px"></div>
                <div class="bg-accent/20 absolute bottom-0 right-[-9999px] left-[-9999px] h-px"></div>
                <CornerDiamond position="all" variant="accent" />
                <SectionDivider variant="grid-broken" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </Panel>
    <SectionDivider />

    {/* Components */}
    <Panel>
      <h2 class="text-accent mb-6 font-mono text-xs tracking-wide">
        COMPONENTS
      </h2>

      <div class="space-y-6">
        <div>
          <p class="text-foreground/50 mb-3 font-mono text-xs">
            Badge variants
          </p>
          <div class="flex flex-wrap gap-2">
            <Badge>default</Badge>
            <Badge variant="accent">accent</Badge>
            <Badge variant="muted">muted</Badge>
            <Badge>TypeScript</Badge>
            <Badge>React</Badge>
            <Badge>Astro</Badge>
          </div>
        </div>

        <div class="border-accent/20 border-t border-dashed"></div>

        <div>
          <p class="text-foreground/50 mb-3 font-mono text-xs">InlineLink</p>
          <p class="text-foreground/80 font-serif text-base">
            A link to <InlineLink href="https://github.com" external
              >GitHub</InlineLink
            > and an
            <InlineLink href="/blog"> internal link</InlineLink>.
          </p>
        </div>

        <div class="border-accent/20 border-t border-dashed"></div>

        <div>
          <p class="text-foreground/50 mb-3 font-mono text-xs">Inline code</p>
          <p class="text-foreground/80 font-serif text-base">
            Use <code>npm install</code> to install, then run <code
              >astro dev</code
            >.
          </p>
        </div>

        <div class="border-accent/20 border-t border-dashed"></div>

        <div>
          <p class="text-foreground/50 mb-3 font-mono text-xs">Code block</p>
          <pre
            class="border-accent/20 bg-muted overflow-x-auto border border-dashed p-4 font-mono text-[0.8125rem] leading-relaxed"><code>{`interface Config {
  site: string;
  output: "static";
  themes: ("kozo" | "manila" | "nightingale")[];
}`}</code></pre>
        </div>

        <div class="border-accent/20 border-t border-dashed"></div>

        <div>
          <p class="text-foreground/50 mb-3 font-mono text-xs">
            CTA Buttons · View Resume / Schedule Call
          </p>
          <div
            class="flex flex-wrap justify-center gap-4 md:justify-start md:gap-8"
          >
            <CtaButton href="#" label="Click Me" shortcut="R" />
            <CtaButton href="#" label="Schedule Call" shortcut="C" />
          </div>
        </div>

        <div class="border-accent/20 border-t border-dashed"></div>

        <div>
          <p class="text-foreground/50 mb-3 font-mono text-xs">Blockquote</p>
          <blockquote
            class="border-accent/30 my-2 border-l border-dashed py-1 pl-5"
          >
            <p
              class="text-foreground/60 font-serif text-base leading-[1.8] italic"
            >
              Design is not just what it looks like and feels like. Design is
              how it works.
            </p>
          </blockquote>
        </div>
      </div>
    </Panel>
    <SectionDivider />

    {/* Spacing */}
    <Panel>
      <h2 class="text-accent mb-6 font-mono text-xs tracking-wide">SPACING</h2>
      <p class="text-foreground/50 mb-4 font-mono text-xs">
        Base unit: 16px grid · All spacing in multiples of 4px
      </p>

      <div class="space-y-2">
        {
          [
            { label: "xs", value: "gap-2 (8px)" },
            { label: "sm", value: "gap-4 (16px)" },
            { label: "md", value: "gap-8 (32px)" },
            { label: "lg", value: "gap-12 (48px)" },
            { label: "xl", value: "gap-16 (64px)" },
          ].map((s) => (
            <div class="flex items-center gap-4">
              <span class="text-foreground w-8 font-mono text-xs">
                {s.label}
              </span>
              <div
                class="bg-accent/20 h-4 flex-1"
                style={`max-width: ${parseInt(s.value.match(/\d+(?=px)/)?.[0] || "16") * 3}px`}
              />
              <span class="text-foreground/50 font-mono text-xs">
                {s.value}
              </span>
            </div>
          ))
        }
      </div>
    </Panel>
    <SectionDivider />

    {/* Animation */}
    <Panel>
      <h2 class="text-accent mb-6 font-mono text-xs tracking-wide">
        ANIMATION
      </h2>

      <div class="space-y-3">
        {
          [
            { label: "instant", value: "0ms" },
            { label: "fast", value: "150ms" },
            { label: "normal", value: "200ms" },
            { label: "slow", value: "300ms" },
            { label: "slower", value: "500ms" },
          ].map((d) => (
            <div class="flex items-center gap-4">
              <span class="text-foreground w-16 font-mono text-xs">
                {d.label}
              </span>
              <span class="text-foreground/50 font-mono text-xs">
                {d.value}
              </span>
            </div>
          ))
        }
      </div>

      <div class="border-accent/20 my-4 border-t border-dashed"></div>

      <p class="text-foreground/50 font-mono text-xs">
        Easing: cubic-bezier(0.215, 0.61, 0.355, 1) · ease-out for entries, ease
        for hovers
      </p>
      <p class="text-foreground/50 mt-1 font-mono text-xs">
        Springs: duration 0.3s, bounce 0 (noBounce) for modals &amp; layout
      </p>
    </Panel>
    <SectionDivider />

    {/* Grid Iterations */}
    <Panel>
      <h2 class="text-accent mb-6 font-mono text-xs tracking-wide">
        GRID ITERATIONS
      </h2>
      <p class="text-foreground/50 mb-6 font-mono text-xs">
        Card iterations for the project and awards grids — cards expand into a
        center modal on click
      </p>
      <GridIterations client:visible />
    </Panel>
    <SectionDivider />

    {/* Edge Ornaments */}
    <Panel>
      <h2 class="text-accent mb-6 font-mono text-xs tracking-wide">
        EDGE ORNAMENTS
      </h2>
      <p class="text-foreground/50 mb-6 font-mono text-xs">
        Ruler-tick and segmented-dash prototypes — placement candidates for the
        site frame, dividers, hero, and timeline
      </p>
      <EdgeOrnaments />
    </Panel>
    <SectionDivider />

    {/* Precision Marks */}
    <Panel>
      <h2 class="text-accent mb-6 font-mono text-xs tracking-wide">
        PRECISION MARKS
      </h2>
      <p class="text-foreground/50 mb-6 font-mono text-xs">
        Drafting-sheet marks — dimensions, title block, coordinates
      </p>
      <PrecisionMarks />
    </Panel>
    <SectionDivider />

    {/* Back */}
    <Panel edges="top">
      <a
        href="/"
