---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Panel from "@/components/ui/Panel";
import SectionDivider from "@/components/ui/SectionDivider";
import Badge from "@/components/ui/Badge";
import { mdxComponents } from "@/components/blog/MDXComponents";
import { SITE, absoluteUrl } from "@/config/site";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter(
    (post) => !post.data.draft || import.meta.env.DEV,
  );
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// Series data
const allPosts = await getCollection("blog");
const seriesPosts = post.data.series
  ? allPosts
      .filter((p) => p.data.series === post.data.series && !p.data.draft)
      .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0))
  : [];
const seriesIcon = seriesPosts[0]?.data.seriesIcon;
const postPath = `/blog/${post.id}`;
const postUrl = absoluteUrl(postPath);
const publishedTime = post.data.date.toISOString();
const articleStructuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${postUrl}#article`,
  headline: post.data.title,
  description: post.data.excerpt,
  datePublished: publishedTime,
  dateModified: publishedTime,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postUrl,
  },
  url: postUrl,
  isPartOf: { "@id": absoluteUrl("/blog/#blog") },
  author: {
    "@type": "Person",
    "@id": absoluteUrl("/#person"),
    name: SITE.name,
    url: SITE.url,
  },
  publisher: {
    "@type": "Person",
    "@id": absoluteUrl("/#person"),
    name: SITE.name,
    url: SITE.url,
  },
  image: absoluteUrl(SITE.socialImage),
  keywords: post.data.tags,
  inLanguage: SITE.language,
};
---

<Layout
  title={`${post.data.title} | Xein Deniel`}
  description={post.data.excerpt}
  canonicalPath={postPath}
  type="article"
  publishedTime={publishedTime}
  modifiedTime={publishedTime}
  keywords={post.data.tags}
  structuredData={articleStructuredData}
>
  <div class="flex flex-col">
          <Panel edges="both" ornaments="all">
      {/* Post header */}
      <div class="mb-6">
        <div class="mb-2 flex items-center justify-between">
          <a
            href="/blog"
            class="text-accent hover:text-tertiary border-accent/30 inline border-b border-dashed pb-px text-sm transition-colors hover:border-solid"
          >
            ← Blogs
          </a>
          <time
            datetime={post.data.date.toISOString()}
            class="text-accent/50 font-mono text-xs tracking-wide tabular-nums"
          >
            {formattedDate}
          </time>
        </div>
        <h1
          class="text-foreground mb-3 font-serif text-2xl [text-wrap:balance]"
        >
          {post.data.title}
        </h1>
        <p class="text-foreground/60 mb-3 text-sm">
          By <a
            href="/"
            rel="author"
            class="text-accent hover:text-tertiary border-accent/30 border-b border-dashed pb-px transition-colors hover:border-solid"
          >
            {SITE.name}
          </a>
        </p>
        {
          post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <Badge>{tag}</Badge>
              ))}
            </div>
          )
        }
      </div>

      {/* Dashed separator */}
      <div class="border-accent/20 mb-6 border-t border-dashed"></div>

      {/* Post content */}
      <article>
        <Content components={mdxComponents} />
      </article>

      {/* Series nav */}
      {
        seriesPosts.length > 1 && (
          <div class="border-accent/15 mt-8 border border-dashed p-5">
            <div class="mb-3 flex items-center gap-2">
              {seriesIcon === "star" && (
                <span class="text-accent text-sm">✦</span>
              )}
              <span class="text-secondary font-mono text-xs tracking-wide uppercase">
                Series
              </span>
            </div>
            <ol class="list-none space-y-1.5 pl-0">
              {seriesPosts.map((sp) => (
                <li class="flex items-start gap-2 text-sm">
                  <span class="text-accent/40 mt-px shrink-0 font-mono text-xs">
                    {sp.data.seriesOrder}.
                  </span>
                  {sp.id === post.id ? (
                    <span class="text-foreground font-serif">
                      {sp.data.title}
                    </span>
                  ) : (
                    <a
                      href={`/blog/${sp.id}`}
                      class="text-accent hover:text-tertiary border-accent/30 border-b border-dashed pb-px font-serif transition-colors hover:border-solid"
                    >
                      {sp.data.title}
                    </a>
                  )}
                </li>
              ))}
            </ol>
          </div>
        )
      }
    </Panel>
    <SectionDivider />

    {/* Navigation */}
    <Panel edges="both" ornaments="all">
      <div class="flex items-center justify-between">
        <a
          href="/blog"
          data-hero-sfx="click"
          class="text-accent hover:text-tertiary border-accent/30 inline border-b border-dashed pb-px text-sm transition-colors hover:border-solid"
        >
          &larr; All posts
        </a>
        <a
          href="/"
          data-hero-sfx="click"
          class="text-accent hover:text-tertiary border-accent/30 inline border-b border-dashed pb-px text-sm transition-colors hover:border-solid"
        >
          Home
        </a>
      </div>
    </Panel>
  </div>
</Layout>
