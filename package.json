{
  "name": "xeind.net",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "PUBLIC_GIT_COMMIT_HASH=$(git rev-parse --short HEAD) PUBLIC_BUILD_DATE=$(date -u +'%Y-%m-%dT%H:%M:%SZ') astro dev --port 3180",
    "build": "PUBLIC_GIT_COMMIT_HASH=$(git rev-parse --short HEAD) PUBLIC_BUILD_DATE=$(date -u +'%Y-%m-%dT%H:%M:%SZ') astro build",
    "preview": "astro preview --port 3181",
    "start": "astro preview --port 3181",
    "check": "astro check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy": "PUBLIC_GIT_COMMIT_HASH=$(git rev-parse --short HEAD) PUBLIC_BUILD_DATE=$(date -u +'%Y-%m-%dT%H:%M:%SZ') npm run build && wrangler pages deploy dist --project-name xeind-net --branch main",
    "deploy:dry": "npm run build",
    "lighthouse": "lighthouse http://localhost:3181 --view --chrome-flags=\"--headless\"",
    "lighthouse:mobile": "lighthouse http://localhost:3181 --preset=mobile --view --chrome-flags=\"--headless\"",
    "lighthouse:ci": "lighthouse http://localhost:3000 --output=json --output=html --output-path=./lighthouse-report --chrome-flags=\"--headless\"",
    "audit": "fallow --production",
    "audit:ci": "fallow --production --ci"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "astro": "^7.0.3",
    "clsx": "^2.1.1",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fallow": "^3.6.0",
    "globals": "^17.7.0",
    "lighthouse": "^13.0.1",
    "lucide-react": "^0.554.0",
    "motion": "^12.23.24",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.46.4",
    "vite": "^8.0.13",
    "wrangler": "^4.104.0"
  },
  "overrides": {
    "vite": "$vite"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "@chenglou/pretext": "^0.0.8"
  }
}
